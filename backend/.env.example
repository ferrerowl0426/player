# 后端服务端口
PORT=3000

# 允许访问后端的前端地址
FRONTEND_URL=http://localhost:3001

# PostgreSQL 数据库连接地址
DATABASE_URL=postgresql://postgres:postgres@localhost:15432/video_player

# 管理员登录 JWT 密钥，本地开发也建议改成随机字符串
JWT_SECRET=dev-secret-change-me

# S3/MinIO 存储桶配置
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=videos
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
# 可选：本地 Docker + MinIO 直传时填写 http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000

# 浏览器访问对象文件时使用的公开地址
# 本地 MinIO 一般就是 http://localhost:9000
PUBLIC_BUCKET_BASE_URL=http://localhost:9000/videos
