# 前端页面地址，用于后端 CORS
FRONTEND_URL=http://你的服务器公网IP:3001

# 浏览器请求后端 API 的公开地址，构建前端镜像时会写入前端包
NEXT_PUBLIC_API_BASE_URL=http://你的服务器公网IP:3002/api

# 管理员登录 JWT 密钥，服务器部署时请改成一段长随机字符串
JWT_SECRET=请改成一段长随机字符串

# 腾讯云 COS / S3 兼容配置
S3_ENDPOINT=https://cos.ap-nanjing.myqcloud.com
S3_REGION=ap-nanjing
S3_BUCKET=你的存储桶名称
S3_ACCESS_KEY_ID=你的SecretId
S3_SECRET_ACCESS_KEY=你的SecretKey
S3_FORCE_PATH_STYLE=false
# 可选：本地 MinIO 直传时填写浏览器可访问的 endpoint，例如 http://localhost:9000
S3_PUBLIC_ENDPOINT=

# 浏览器访问视频和封面时使用的公开 COS 地址
PUBLIC_BUCKET_BASE_URL=https://你的存储桶名称.cos.ap-nanjing.myqcloud.com
